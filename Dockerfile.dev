FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY docker-entrypoint.sh .
RUN sed -i 's/\r$//' docker-entrypoint.sh && chmod +x docker-entrypoint.sh

RUN mkdir -p uploads

EXPOSE 5000

ENTRYPOINT ["./docker-entrypoint.sh"]
CMD ["npx", "nodemon", "src/server.js"]
